{
  "name": "jinncore",
  "version": "0.0.5",
  "license": "Apache-2.0",
  "homepage": "https://jinncore.org",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jinn-core/jinncore.git"
  },
  "files": [
    "dist",
    "SPEC.md",
    "test-vectors"
  ],
  "description": "The Jinn protocol core: wire-grammar specification, reference implementation, test vectors.",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./wire": {
      "types": "./dist/wire.d.ts",
      "import": "./dist/wire.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "test:watch": "vitest",
    "check": "tsc -p tsconfig.check.json",
    "vectors": "tsx scripts/generate-vectors.ts",
    "prepublishOnly": "npm run check && npm test && npm run build"
  },
  "dependencies": {
    "@noble/ed25519": "^2.1.0"
  },
  "devDependencies": {
    "@types/node": "^22.20.1",
    "tsx": "^4.23.1",
    "typescript": "^5.5.0",
    "vitest": "^2.0.0"
  }
}
